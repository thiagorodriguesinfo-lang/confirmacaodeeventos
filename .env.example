# ==============================================================================
# BANCO DE DADOS (PostgreSQL / Supabase)
# ==============================================================================
# String de conexao direta (usada por Prisma Migrate)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/confirmacaodeeventos?schema=public"
# String de conexao via pooler (recomendada em runtime serverless na Supabase)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/confirmacaodeeventos?schema=public"

# ==============================================================================
# SUPABASE (armazenamento de imagens de convite, autenticacao opcional)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
SUPABASE_STORAGE_BUCKET="convites"

# ==============================================================================
# AUTENTICACAO
# ==============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
JWT_SECRET="gere-com-openssl-rand-base64-32"

# ==============================================================================
# WHATSAPP — selecao do provider ativo: "baileys" | "evolution_api" | "meta_cloud_api"
#
# "baileys" = WhatsApp embutido e GRATIS (conecta via QR Code, socket roda dentro
# do proprio worker do sistema; nao precisa de servico externo nem credenciais).
# Pasta da sessao do Baileys (montar em volume para persistir o login):
BAILEYS_AUTH_DIR="./baileys-auth"
#
# Estas variaveis sao usadas apenas como FALLBACK. A forma recomendada de
# configurar o WhatsApp e pelo painel, em Administração → WhatsApp
# (/dashboard/settings/whatsapp), que grava as credenciais no banco e
# permite conectar o numero via QR Code sem precisar editar o servidor.
# ==============================================================================
WHATSAPP_PROVIDER="baileys"

# --- Meta WhatsApp Cloud API ---------------------------------------------
META_WHATSAPP_TOKEN="seu-token-permanente-da-meta"
META_WHATSAPP_PHONE_NUMBER_ID="id-do-numero-de-telefone"
META_WHATSAPP_BUSINESS_ACCOUNT_ID="id-da-conta-de-negocios"
META_WEBHOOK_VERIFY_TOKEN="defina-um-token-secreto-para-validar-o-webhook"
META_APP_SECRET="app-secret-para-validar-assinatura-x-hub-signature"
META_GRAPH_API_VERSION="v21.0"

# --- Evolution API (self-hosted / open source) ---------------------------
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key-da-evolution"
EVOLUTION_INSTANCE_NAME="confirmacaodeeventos"
EVOLUTION_WEBHOOK_SECRET="defina-um-token-secreto-para-validar-o-webhook"

# ==============================================================================
# APP
# ==============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="defina-um-token-secreto-para-jobs-agendados"

# Rate limit padrao de disparo (mensagens por minuto) caso nao especificado na UI
DEFAULT_DISPATCH_RATE_PER_MINUTE=20
